sound = /button_sounds/languages/zh/milk_牛奶.wav
position = 1

[water]
label = Water
text_description = Water / 水
image = /lcd_images/8_Icons-02.bmp
sound = /button_sounds/languages/zh/water_水.wav
position = 2

[snack]
label = Snack
text_description = Snack / 零食
